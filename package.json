{
  "name": "gome",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "vite --config ./client/vite.config.js --configLoader runner",
    "dev:server": "npm --prefix ./server run dev",
    "build": "npm run build:client",
    "build:client": "vite build --config ./client/vite.config.js --configLoader runner",
    "lint": "eslint client",
    "preview": "npm run preview:client",
    "preview:client": "vite preview --config ./client/vite.config.js --configLoader runner"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.3",
    "three": "^0.183.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
